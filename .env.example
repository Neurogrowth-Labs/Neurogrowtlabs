# Firebase web client configuration used by the current frontend.
# Keep secrets such as service-role keys out of Vite/client env variables.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID="(default)"

# Supabase backend to create from supabase/production_schema.sql.
# Use these when migrating the frontend from Firebase SDK to Supabase JS.
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""
