{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the NeuroGrowth Labs platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's Firebase Auth UID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "A saved AI analysis or query result.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "search", "maps"] },
        "query": { "type": "string" },
        "result": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "query", "result", "createdAt"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A chat session created for anonymous or logged-in users.",
      "type": "object",
      "properties": {}
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message within a chat session.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "ai", "system"] },
        "text": { "type": "string" },
        "systemPromptContext": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "analyses/{analysisId}": {
      "schema": { "$ref": "#/entities/Analysis" },
      "description": "Stores saved AI analyses for users."
    },
    "chat_sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Stores chat sessions.",
      "subcollections": {
        "messages/{messageId}": {
          "schema": { "$ref": "#/entities/ChatMessage" },
          "description": "Stores chat messages."
        }
      }
    }
  }
}
